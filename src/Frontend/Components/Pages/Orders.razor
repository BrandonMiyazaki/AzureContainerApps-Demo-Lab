@page "/orders"
@using Frontend.Services
@inject OrdersApiClient Api
@rendermode InteractiveServer

<PageTitle>Orders — Miyazaki Retail</PageTitle>

<h1>Orders</h1>

<div class="mb-3">
    <input type="text" class="form-control" placeholder="Search by customer name or order #..."
           @bind="_searchTerm" @bind:event="oninput" />
</div>

@if (_loading)
{
    <p><em>Loading...</em></p>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Order #</th>
                <th>Customer</th>
                <th>Date</th>
                <th>Items</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in FilteredOrders)
            {
                <tr @onclick="() => SelectOrder(order)" style="cursor: pointer;">
                    <td>@order.Id</td>
                    <td>@CustomerName(order)</td>
                    <td>@order.OrderDate.ToString("g")</td>
                    <td>@order.OrderItems.Count</td>
                    <td>@order.TotalAmount.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>

    @if (_selectedOrder is not null)
    {
        <div class="card mt-3">
            <div class="card-header">
                <h5>Order #@_selectedOrder.Id Details</h5>
            </div>
            <div class="card-body">
                <p><strong>Customer:</strong> @CustomerName(_selectedOrder)</p>
                <p><strong>Date:</strong> @_selectedOrder.OrderDate.ToString("f")</p>
                <table class="table table-sm">
                    <thead>
                        <tr><th>Product</th><th>Qty</th><th>Unit Price</th><th>Subtotal</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _selectedOrder.OrderItems)
                        {
                            <tr>
                                <td>@(item.Product?.Name ?? $"Product #{item.ProductId}")</td>
                                <td>@item.Quantity</td>
                                <td>@item.UnitPrice.ToString("C")</td>
                                <td>@((item.Quantity * item.UnitPrice).ToString("C"))</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr><td colspan="3" class="text-end fw-bold">Total</td><td class="fw-bold">@_selectedOrder.TotalAmount.ToString("C")</td></tr>
                    </tfoot>
                </table>
                <button class="btn btn-secondary btn-sm" @onclick="() => _selectedOrder = null">Close</button>
            </div>
        </div>
    }
}

@code {
    private bool _loading = true;
    private string? _error;
    private string _searchTerm = string.Empty;
    private List<Frontend.Models.Order> _orders = [];
    private Frontend.Models.Order? _selectedOrder;

    private IEnumerable<Frontend.Models.Order> FilteredOrders =>
        string.IsNullOrWhiteSpace(_searchTerm)
            ? _orders
            : _orders.Where(o =>
                o.Id.ToString().Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                CustomerName(o).Contains(_searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _orders = await Api.GetOrdersAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load orders: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void SelectOrder(Frontend.Models.Order order) => _selectedOrder = order;

    private static string CustomerName(Frontend.Models.Order order) =>
        order.Customer is not null
            ? $"{order.Customer.FirstName} {order.Customer.LastName}"
            : "—";
}
