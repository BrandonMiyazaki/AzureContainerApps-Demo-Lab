@page "/customers"
@using Frontend.Services
@inject OrdersApiClient Api
@rendermode InteractiveServer

<PageTitle>Customers — @StoreName</PageTitle>

<h1>Customers</h1>

@if (_loading)
{
    <p><em>Loading...</em></p>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>City</th>
                <th>State</th>
                <th>Orders</th>
                <th>Joined</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var customer in _customers)
            {
                <tr @onclick="() => ToggleCustomer(customer.Id)" style="cursor: pointer;">
                    <td>@customer.FirstName @customer.LastName</td>
                    <td>@customer.Email</td>
                    <td>@customer.City</td>
                    <td>@customer.State</td>
                    <td>@OrderCountFor(customer.Id)</td>
                    <td>@customer.CreatedAt.ToString("d")</td>
                </tr>

                @if (_expandedCustomerId == customer.Id)
                {
                    <tr>
                        <td colspan="6">
                            <div class="p-2 bg-light">
                                <h6>Order History</h6>
                                @{ var customerOrders = OrdersFor(customer.Id); }
                                @if (customerOrders.Count == 0)
                                {
                                    <p class="text-muted mb-0">No orders yet.</p>
                                }
                                else
                                {
                                    <table class="table table-sm mb-0">
                                        <thead><tr><th>Order #</th><th>Date</th><th>Items</th><th>Total</th><th></th></tr></thead>
                                        <tbody>
                                            @foreach (var order in customerOrders)
                                            {
                                                <tr @onclick="() => ToggleOrder(order.Id)" @onclick:stopPropagation="true" style="cursor: pointer;">
                                                    <td>@order.Id</td>
                                                    <td>@order.OrderDate.ToString("g")</td>
                                                    <td>@order.OrderItems.Count</td>
                                                    <td>@order.TotalAmount.ToString("C")</td>
                                                    <td><span class="text-muted small">@(_expandedOrderId == order.Id ? "▲" : "▼")</span></td>
                                                </tr>
                                                @if (_expandedOrderId == order.Id)
                                                {
                                                    <tr>
                                                        <td colspan="5">
                                                            <table class="table table-bordered table-sm mb-0 ms-3" style="max-width: 95%;">
                                                                <thead class="table-light">
                                                                    <tr><th>Product</th><th>Qty</th><th>Unit Price</th><th>Subtotal</th></tr>
                                                                </thead>
                                                                <tbody>
                                                                    @foreach (var item in order.OrderItems)
                                                                    {
                                                                        <tr>
                                                                            <td>@(item.Product?.Name ?? $"Product #{item.ProductId}")</td>
                                                                            <td>@item.Quantity</td>
                                                                            <td>@item.UnitPrice.ToString("C")</td>
                                                                            <td>@((item.Quantity * item.UnitPrice).ToString("C"))</td>
                                                                        </tr>
                                                                    }
                                                                </tbody>
                                                            </table>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    [CascadingParameter(Name = "StoreName")]
    public string StoreName { get; set; } = "Retail Demo";

    private bool _loading = true;
    private string? _error;
    private List<Frontend.Models.Customer> _customers = [];
    private List<Frontend.Models.Order> _orders = [];
    private int? _expandedCustomerId;
    private int? _expandedOrderId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var customersTask = Api.GetCustomersAsync();
            var ordersTask = Api.GetOrdersAsync();
            await Task.WhenAll(customersTask, ordersTask);
            _customers = customersTask.Result;
            _orders = ordersTask.Result;
        }
        catch (Exception ex)
        {
            _error = $"Failed to load customers: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void ToggleCustomer(int id)
    {
        _expandedCustomerId = _expandedCustomerId == id ? null : id;
        _expandedOrderId = null; // collapse any open order when switching customers
    }

    private void ToggleOrder(int id) =>
        _expandedOrderId = _expandedOrderId == id ? null : id;

    private int OrderCountFor(int customerId) =>
        _orders.Count(o => o.CustomerId == customerId);

    private List<Frontend.Models.Order> OrdersFor(int customerId) =>
        _orders.Where(o => o.CustomerId == customerId).ToList();
}
